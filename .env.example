# Required
DATABASE_URL=postgresql://rigelhq:rigelhq@localhost:5432/rigelhq
REDIS_URL=redis://localhost:6379

# Claude Agent SDK uses Claude Code CLI auth (run `claude login` first)
# No API key needed — agents spawn via the Claude Code CLI process

# Optional — Voice (Phase 2)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Configuration
RIGELHQ_ADAPTER=mock
RIGELHQ_MAX_CONCURRENT_AGENTS=5
RIGELHQ_TOKEN_BUDGET_DAILY=1000000
RIGELHQ_WEB_PORT=3000
RIGELHQ_ORCHESTRATOR_PORT=4000
